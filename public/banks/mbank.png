        <div class="container-1200 foot-container" id="container-contact">
            <h2 class="section-h2">Kontakt</h2>
            <div class="wrapper bg-burgundy">
                <div class="text-above-form text-center text-uppercase bold">Masz pytania? Zapraszamy do kontaktu:</div>
                <form id="contactForm">
                    <div class="contactForm">
                        <div class="contactFormFlex row inputs mt-4 mb-3">
                            <div class="col-left">
                                <div class="form-row">
                                    <input type="text" name="data[name]" placeholder="Imię i nazwisko" tabindex="1">
